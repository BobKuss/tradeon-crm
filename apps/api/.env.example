# TradEon API — environment variables
# Copy to .env and fill in real values before starting.

# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradeon_crm?schema=public"

# ─── API ───────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ─── Staff JWT ─────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod
JWT_REFRESH_EXPIRES_IN=7d

# ─── Portal JWT (separate audience) ───────────────────────
PORTAL_JWT_SECRET=dev_portal_jwt_secret_change_in_prod
PORTAL_JWT_EXPIRES_IN=15m
PORTAL_JWT_REFRESH_SECRET=dev_portal_refresh_secret_change_in_prod
PORTAL_JWT_REFRESH_EXPIRES_IN=7d
