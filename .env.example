# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://tradeon:tradeon_dev@localhost:5432/tradeon_crm?schema=public"

# ─── API (NestJS) ──────────────────────────────────────────────────────────────
API_PORT=3001
API_PREFIX=api
NODE_ENV=development

# ─── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── JWT — staff CRM ──────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_in_production_refresh
JWT_REFRESH_EXPIRES_IN=7d

# ─── JWT — B2B portal (separate secrets from staff JWT) ───────────────────────
PORTAL_JWT_SECRET=change_me_portal_in_production
PORTAL_JWT_EXPIRES_IN=15m
PORTAL_JWT_REFRESH_SECRET=change_me_portal_refresh_in_production
PORTAL_JWT_REFRESH_EXPIRES_IN=7d

# ─── Portal origin (for CORS) ─────────────────────────────────────────────────
# Set to where portal.html is served, e.g. http://127.0.0.1:5500 (VS Code Live Server)
PORTAL_URL=http://127.0.0.1:5500

# ─── Redis (add when implementing cache) ──────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
